{
  "name": "ezybus",
  "version": "1.0.0",
  "description": "EzyBus - Full-Stack Bus Management Platform",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "install:all": "npm install && npm install --prefix backend && npm install --prefix frontend && npm install --prefix shared",
    "build": "npm run build --prefix frontend",
    "lint": "npm run lint --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "dependencies": {
    "firebase": "^12.11.0",
    "leaflet": "^1.9.4"
  }
}
